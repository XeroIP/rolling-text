<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/aboutScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/aboutContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Back button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/backButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_back"
            android:layout_marginBottom="16dp"
            app:icon="@drawable/ic_back" />

        <!-- Title -->
        <TextView
            android:id="@+id/aboutTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Intro paragraphs -->
        <TextView
            android:id="@+id/aboutIntro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_intro"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/aboutConcept"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_concept"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/aboutPower"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_power"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/aboutScienceIntro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_science_intro"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:textStyle="italic"
            android:layout_marginBottom="24dp" />

        <!-- Study 1 -->
        <TextView
            android:id="@+id/study1Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_study1_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/study1Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_study1_body"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/study1Citation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_study1_citation"
            android:textSize="13sp"
            android:textStyle="italic"
            android:layout_marginBottom="24dp" />

        <!-- Study 2 -->
        <TextView
            android:id="@+id/study2Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_study2_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/study2Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_study2_body"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/study2Citation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_study2_citation"
            android:textSize="13sp"
            android:textStyle="italic"
            android:layout_marginBottom="24dp" />

        <!-- Study 3 -->
        <TextView
            android:id="@+id/study3Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_study3_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/study3Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_study3_body"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/study3Citation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_study3_citation"
            android:textSize="13sp"
            android:textStyle="italic"
            android:layout_marginBottom="24dp" />

        <!-- Study 4 -->
        <TextView
            android:id="@+id/study4Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_study4_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/study4Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_study4_body"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/study4Citation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_study4_citation"
            android:textSize="13sp"
            android:textStyle="italic"
            android:layout_marginBottom="24dp" />

        <!-- Closing -->
        <TextView
            android:id="@+id/aboutClosing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_closing"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="32dp" />

    </LinearLayout>

</ScrollView>
